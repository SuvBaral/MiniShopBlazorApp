{
  "name": "git-buddy",
  "displayName": "Git Buddy",
  "description": "Your friendly Git companion for VS Code. Team Explorer-style panel with natural language commands — type 'switch to main' or 'merge develop' instead of memorizing git syntax. Full staging, history, conflict resolution, and AI commit messages built in.",
  "version": "1.0.0",
  "publisher": "YOUR-PUBLISHER-ID",
  "license": "MIT",
  "author": {
    "name": "Shubham"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/YOUR-USERNAME/GitBuddy"
  },
  "homepage": "https://github.com/YOUR-USERNAME/GitBuddy#readme",
  "bugs": {
    "url": "https://github.com/YOUR-USERNAME/GitBuddy/issues"
  },
  "engines": {
    "vscode": "^1.107.0"
  },
  "categories": [
    "SCM Providers",
    "Other"
  ],
  "keywords": [
    "git",
    "source control",
    "team explorer",
    "branches",
    "natural language",
    "ai",
    "staging",
    "commit",
    "diff",
    "git buddy",
    "blazor"
  ],
  "icon": "images/icon.png",
  "galleryBanner": {
    "color": "#1e1e2e",
    "theme": "dark"
  },
  "activationEvents": [
    "onStartupFinished",
    "workspaceContains:.git"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "gitBuddy",
          "title": "Git Buddy",
          "icon": "images/git-simple.svg"
        }
      ]
    },
    "views": {
      "gitBuddy": [
        {
          "type": "webview",
          "id": "gitBuddy.mainView",
          "name": "Git Buddy"
        }
      ]
    },
    "commands": [
      {
        "command": "gitBuddy.refresh",
        "title": "Refresh",
        "icon": "$(refresh)",
        "category": "Git Buddy"
      },
      {
        "command": "gitBuddy.nlCommand",
        "title": "Git Command (Natural Language)",
        "icon": "$(comment)",
        "category": "Git Buddy"
      }
    ],
    "keybindings": [
      {
        "command": "gitBuddy.nlCommand",
        "key": "ctrl+shift+g ctrl+shift+n",
        "when": "workspaceFolderCount > 0"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "gitBuddy.refresh",
          "when": "view == gitBuddy.mainView",
          "group": "navigation"
        },
        {
          "command": "gitBuddy.nlCommand",
          "when": "view == gitBuddy.mainView",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Git Buddy",
      "properties": {
        "gitBuddy.nlProvider": {
          "type": "string",
          "default": "auto",
          "enum": ["auto", "copilot", "offline"],
          "enumDescriptions": [
            "Use Copilot if available, fall back to offline pattern matching",
            "Always use GitHub Copilot (requires Copilot extension)",
            "Offline pattern matching only — no AI calls"
          ],
          "description": "AI provider for natural language command translation."
        },
        "gitBuddy.confirmModerate": {
          "type": "boolean",
          "default": true,
          "description": "Ask for confirmation before moderate-risk operations (merge, rebase, checkout)."
        },
        "gitBuddy.autoBackupOnDangerous": {
          "type": "boolean",
          "default": true,
          "description": "Automatically stash uncommitted changes before dangerous operations (hard reset, force push, etc.)."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "powershell -ExecutionPolicy Bypass -File ../../build.ps1 && npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.19.37",
    "@types/vscode": "^1.107.0",
    "@vscode/vsce": "^3.7.1",
    "ovsx": "^0.10.10",
    "typescript": "^5.9.3"
  }
}
