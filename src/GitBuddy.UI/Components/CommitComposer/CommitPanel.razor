@using GitBuddy.UI.Models
@inject GitService Git

<div class="commit-panel">
    <div class="section-header" @onclick="() => _expanded = !_expanded">
        <span class="chevron @(_expanded ? "open" : "")">&#9654;</span>
        COMMIT
        @if (_stagedCount > 0)
        {
            <span class="count">@_stagedCount staged</span>
        }
    </div>

    @if (_expanded)
    {
        <!-- Commit Message Input -->
        <div style="padding:6px 8px;">
            <!-- Template Selector -->
            <div style="margin-bottom:4px;display:flex;align-items:center;gap:4px;">
                <select class="nl-input" style="padding:3px 6px;font-size:11px;"
                        @onchange="SelectTemplate">
                    <option value="">No template</option>
                    @foreach (var tmpl in CommitTemplate.BuiltIn)
                    {
                        <option value="@tmpl.Name">@tmpl.Name — @tmpl.Description</option>
                    }
                </select>
            </div>

            <textarea class="commit-textarea"
                      placeholder="Commit message... (Ctrl+Enter to commit)"
                      @bind="_commitMessage"
                      @bind:event="oninput"
                      @bind:after="OnMessageChanged"
                      @onkeydown="HandleKeyDown"
                      rows="3"></textarea>

            <div style="display:flex;gap:4px;margin-top:4px;">
                <button class="btn btn-primary" style="flex:1;font-size:11px;"
                        @onclick="DoCommit"
                        disabled="@(string.IsNullOrWhiteSpace(_commitMessage) || _stagedCount == 0)">
                    &#10003; Commit (@_stagedCount)
                </button>
                <button class="btn btn-secondary" style="font-size:11px;"
                        title="Generate AI commit message"
                        @onclick="GenerateMessage">
                    &#9733; AI
                </button>
                <button class="btn btn-secondary" style="font-size:11px;"
                        title="@(string.IsNullOrWhiteSpace(_commitMessage) ? "Enter a message to amend the commit" : "Amend last commit with this message")"
                        disabled="@string.IsNullOrWhiteSpace(_commitMessage)"
                        @onclick="DoAmend">
                    &#8634; Amend
                </button>
            </div>

            @if (_isGenerating)
            {
                <div style="padding:4px 0;display:flex;align-items:center;gap:6px;font-size:11px;color:var(--vscode-descriptionForeground);">
                    <LoadingSpinner Visible="true" /> Generating commit message...
                </div>
            }
        </div>
    }
</div>

@code {
    private string _commitMessage = "";
    private int _stagedCount;
    private bool _expanded = true;
    private bool _isGenerating;

    [Parameter] public EventCallback<string> OnToast { get; set; }
    [Parameter] public EventCallback<string> OnError { get; set; }
    [Parameter] public EventCallback OnRefresh { get; set; }
    [Parameter] public EventCallback<(string Title, string Message, Func<Task> OnConfirm)> OnConfirmRequest { get; set; }

    // @bind:after callback — called after _commitMessage is updated, triggers UI refresh
    private void OnMessageChanged() => StateHasChanged();

    public async Task RefreshStagedCount()
    {
        try
        {
            var result = await Git.GetStagedChanges();
            if (result?.Success == true)
            {
                _stagedCount = string.IsNullOrWhiteSpace(result.Output) ? 0
                    : result.Output.Split('\n', StringSplitOptions.RemoveEmptyEntries).Length;
            }
            else
            {
                _stagedCount = 0;
            }
        }
        catch
        {
            _stagedCount = 0;
        }
        _isGenerating = false; // reset any stuck state
        StateHasChanged();
    }

    private async Task HandleKeyDown(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && e.CtrlKey && !string.IsNullOrWhiteSpace(_commitMessage) && _stagedCount > 0)
        {
            await DoCommit();
        }
    }

    private void SelectTemplate(ChangeEventArgs e)
    {
        var name = e.Value?.ToString();
        if (string.IsNullOrEmpty(name))
        {
            _commitMessage = ""; // "No template" clears so user can type freely
            return;
        }

        var tmpl = CommitTemplate.BuiltIn.FirstOrDefault(t => t.Name == name);
        if (tmpl is not null)
            _commitMessage = tmpl.Format;
    }

    private async Task DoCommit()
    {
        if (string.IsNullOrWhiteSpace(_commitMessage)) return;

        var result = await Git.Commit(_commitMessage);
        if (result?.Success == true)
        {
            await OnToast.InvokeAsync("Committed successfully!");
            _commitMessage = "";
            _stagedCount = 0;
            await OnRefresh.InvokeAsync();
        }
        else
        {
            await OnError.InvokeAsync(result?.Error ?? "Commit failed");
        }
    }

    private async Task DoAmend()
    {
        if (string.IsNullOrWhiteSpace(_commitMessage)) return;
        await OnConfirmRequest.InvokeAsync((
            "Amend Last Commit",
            "This will modify the last commit. Are you sure?",
            async () =>
            {
                var result = await Git.CommitAmend(_commitMessage);
                if (result?.Success == true)
                {
                    await OnToast.InvokeAsync("Commit amended!");
                    _commitMessage = "";
                    await OnRefresh.InvokeAsync();
                }
                else
                {
                    await OnError.InvokeAsync(result?.Error ?? "Amend failed");
                }
            }
        ));
    }

    private async Task GenerateMessage()
    {
        _isGenerating = true;
        StateHasChanged();

        var result = await Git.GenerateCommitMessage();
        if (result?.Success == true && !string.IsNullOrWhiteSpace(result.Output))
        {
            _commitMessage = result.Output.Trim();
        }
        else
        {
            await OnError.InvokeAsync(result?.Error is not null
                ? $"AI generation failed: {result.Error}"
                : "No staged changes to generate a message from.");
        }

        _isGenerating = false;
        StateHasChanged();
    }
}