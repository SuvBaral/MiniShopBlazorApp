@using GitBuddy.Core.Models
@using GitBuddy.UI.Models

<div class="branch-item @(Branch.IsCurrent ? "current selected" : "") @(IsRemote ? "remote-item" : "")"
     @onclick="OnClick"
     @oncontextmenu="OnRightClick"
     @oncontextmenu:preventDefault="true">
    <span class="icon">@(Branch.IsCurrent ? "✓" : "")</span>
    <span class="branch-name">@DisplayName</span>
    @if (Branch.IsCurrent && SyncInfo is not null)
    {
        <SyncBadge Info="SyncInfo" />
    }
</div>

@code {
    [Parameter, EditorRequired] public Branch Branch { get; set; } = default!;
    [Parameter] public SyncInfo? SyncInfo { get; set; }
    [Parameter] public bool IsRemote { get; set; }
    [Parameter] public EventCallback<Branch> OnSelected { get; set; }
    [Parameter] public EventCallback<(Branch Branch, double X, double Y)> OnContextMenu { get; set; }

    private string DisplayName => IsRemote && Branch.Name.Contains('/')
        ? Branch.Name[(Branch.Name.IndexOf('/') + 1)..]
        : Branch.Name;

    private async Task OnClick() => await OnSelected.InvokeAsync(Branch);

    private async Task OnRightClick(Microsoft.AspNetCore.Components.Web.MouseEventArgs e)
    {
        await OnContextMenu.InvokeAsync((Branch, e.ClientX, e.ClientY));
    }
}
