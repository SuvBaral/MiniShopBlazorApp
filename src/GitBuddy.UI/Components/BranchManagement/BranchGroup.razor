@using GitBuddy.UI.Models

<div class="section-header" @onclick="Toggle">
    <span class="chevron @(IsExpanded ? "open" : "")">&#9654;</span>
    <span>@Title @(Count > 0 ? $"({Count})" : "")</span>
</div>

@if (IsExpanded)
{
    @ChildContent
}

@code {
    [Parameter, EditorRequired] public string Title { get; set; } = string.Empty;
    [Parameter] public int Count { get; set; }
    [Parameter] public bool InitiallyExpanded { get; set; } = true;
    [Parameter] public RenderFragment? ChildContent { get; set; }

    private bool IsExpanded;

    protected override void OnInitialized() => IsExpanded = InitiallyExpanded;

    private void Toggle() => IsExpanded = !IsExpanded;
}
