@using GitBuddy.UI.Models
@inject GitService Git
@inject IJSRuntime JS

<div class="commit-history">
    <div class="section-header" @onclick="() => _expanded = !_expanded">
        <span class="chevron @(_expanded ? "open" : "")">&#9654;</span>
        COMMIT HISTORY
        <span class="count">@_commits.Count</span>
    </div>

    @if (_expanded)
    {
        <div style="padding:4px 8px;">
            <input class="nl-input" placeholder="Search commits..."
                   style="font-size:11px;padding:3px 8px;"
                   @bind="_searchText" @bind:event="oninput" />
        </div>

        <div class="history-list">
            @foreach (var commit in FilteredCommits)
            {
                <div class="history-item @(commit.Hash == _selectedHash ? "selected" : "")"
                     @onclick="() => SelectCommit(commit)"
                     @oncontextmenu="e => ShowCommitMenu(e, commit)"
                     @oncontextmenu:preventDefault="true">
                    <div class="history-graph-col">
                        <div class="graph-dot" style="background:@GetBranchColor(commit);"></div>
                    </div>
                    <div class="history-content">
                        <div class="history-message">@TruncateMessage(commit.Message)</div>
                        <div class="history-meta">
                            <span class="history-hash">@commit.ShortHash</span>
                            <span class="history-author">@commit.Author</span>
                            <span class="history-date">@FormatDate(commit.Date)</span>
                        </div>
                        @if (commit.Refs.Length > 0)
                        {
                            <div class="history-refs">
                                @foreach (var r in commit.Refs)
                                {
                                    <span class="history-ref @GetRefClass(r)">@r</span>
                                }
                            </div>
                        }
                    </div>
                </div>
            }

            @if (_commits.Count > 0)
            {
                <div style="padding:4px 8px;">
                    <button class="btn btn-secondary" style="width:100%;font-size:11px;" @onclick="LoadMore">
                        Load more...
                    </button>
                </div>
            }
        </div>
    }
</div>

@if (_showMenu)
{
    <ContextMenu X="_menuX" Y="_menuY" OnClose="() => _showMenu = false">
        <ContextMenuItem Label="Cherry-pick this commit" OnClick="CherryPick" />
        <ContextMenuItem Label="Create branch from here..." OnClick="CreateBranchFromCommit" />
        <ContextMenuItem Label="Create tag here..." OnClick="CreateTagFromCommit" />
        <Separator />
        <ContextMenuItem Label="Copy commit hash" OnClick="CopyHash" />
        <ContextMenuItem Label="Copy commit message" OnClick="CopyMessage" />
    </ContextMenu>
}

@code {
    private List<CommitInfo> _commits = new();
    private string _selectedHash = "";
    private string _searchText = "";
    private bool _expanded = false;
    private int _loadCount = 50;
    private bool _showMenu;
    private double _menuX, _menuY;
    private CommitInfo? _menuCommit;

    private string[] _branchColors = { "#3794ff", "#388a34", "#cca700", "#f14c4c", "#b180d7", "#4ec9b0", "#ce9178", "#569cd6" };

    [Parameter] public EventCallback<string> OnToast { get; set; }
    [Parameter] public EventCallback<string> OnError { get; set; }
    [Parameter] public EventCallback OnRefresh { get; set; }
    [Parameter] public EventCallback<(string Title, string Placeholder, Func<string, Task> OnSubmit)> OnInputRequest { get; set; }

    public async Task LoadHistory()
    {
        var result = await Git.GetCommitLog(_loadCount);
        if (result?.Success == true && !string.IsNullOrWhiteSpace(result.Output))
        {
            _commits = ParseCommits(result.Output);
        }
        StateHasChanged();
    }

    private List<CommitInfo> ParseCommits(string output)
    {
        var commits = new List<CommitInfo>();
        foreach (var line in output.Split('\n', StringSplitOptions.RemoveEmptyEntries))
        {
            var parts = line.Split('|');
            if (parts.Length < 6) continue;

            commits.Add(new CommitInfo(
                Hash: parts[0].Trim(),
                ShortHash: parts[0].Trim().Length > 7 ? parts[0].Trim()[..7] : parts[0].Trim(),
                Message: parts[1].Trim(),
                Author: parts[2].Trim(),
                AuthorEmail: parts[3].Trim(),
                Date: parts[4].Trim(),
                Parents: parts.Length > 5 ? parts[5].Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries) : Array.Empty<string>(),
                Refs: parts.Length > 6 && !string.IsNullOrWhiteSpace(parts[6])
                    ? parts[6].Trim().Split(',', StringSplitOptions.RemoveEmptyEntries).Select(r => r.Trim()).ToArray()
                    : Array.Empty<string>()
            ));
        }
        return commits;
    }

    private IEnumerable<CommitInfo> FilteredCommits => string.IsNullOrWhiteSpace(_searchText)
        ? _commits
        : _commits.Where(c =>
            c.Message.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ||
            c.Author.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ||
            c.ShortHash.Contains(_searchText, StringComparison.OrdinalIgnoreCase));

    private string GetBranchColor(CommitInfo commit) =>
        _branchColors[Math.Abs(commit.Hash.GetHashCode()) % _branchColors.Length];

    private string GetRefClass(string r) =>
        r.Contains("HEAD") ? "ref-head" : r.Contains("tag:") ? "ref-tag" : "ref-branch";

    private string TruncateMessage(string msg) =>
        msg.Length > 60 ? msg[..57] + "..." : msg;

    private string FormatDate(string date) =>
        DateTime.TryParse(date, out var d) ? d.ToString("MMM dd") : date;

    private async Task SelectCommit(CommitInfo commit)
    {
        _selectedHash = commit.Hash;
    }

    private void ShowCommitMenu(Microsoft.AspNetCore.Components.Web.MouseEventArgs e, CommitInfo commit)
    {
        _menuCommit = commit;
        _menuX = e.ClientX;
        _menuY = e.ClientY;
        _showMenu = true;
    }

    private async Task CherryPick()
    {
        _showMenu = false;
        if (_menuCommit is null) return;
        var result = await Git.CherryPick(_menuCommit.Hash);
        if (result?.Success == true)
            await OnToast.InvokeAsync($"Cherry-picked {_menuCommit.ShortHash}");
        else
            await OnError.InvokeAsync(result?.Error ?? "Cherry-pick failed");
        await OnRefresh.InvokeAsync();
    }

    private async Task CreateBranchFromCommit()
    {
        _showMenu = false;
        if (_menuCommit is null) return;
        await OnInputRequest.InvokeAsync((
            "New Branch",
            "Branch name",
            async (string name) =>
            {
                var result = await Git.CreateBranch(name, _menuCommit.Hash);
                if (result?.Success == true) await OnToast.InvokeAsync($"Created branch {name}");
                else await OnError.InvokeAsync(result?.Error ?? "Failed to create branch");
                await OnRefresh.InvokeAsync();
            }
        ));
    }

    private async Task CreateTagFromCommit()
    {
        _showMenu = false;
        if (_menuCommit is null) return;
        await OnInputRequest.InvokeAsync((
            "New Tag",
            "Tag name (e.g. v1.0.0)",
            async (string name) =>
            {
                var result = await Git.CreateTag(name, null, _menuCommit.Hash);
                if (result?.Success == true) await OnToast.InvokeAsync($"Created tag {name}");
                else await OnError.InvokeAsync(result?.Error ?? "Failed to create tag");
                await OnRefresh.InvokeAsync();
            }
        ));
    }

    private async Task CopyHash()
    {
        _showMenu = false;
        if (_menuCommit is null) return;
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", _menuCommit.Hash);
        await OnToast.InvokeAsync($"Copied: {_menuCommit.ShortHash}");
    }

    private async Task CopyMessage()
    {
        _showMenu = false;
        if (_menuCommit is null) return;
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", _menuCommit.Message);
        await OnToast.InvokeAsync("Commit message copied");
    }

    private async Task LoadMore()
    {
        _loadCount += 50;
        await LoadHistory();
    }
}