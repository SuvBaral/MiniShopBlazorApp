@using GitBuddy.UI.Models

<div class="branch-item staging-file-item" @ondblclick="() => OnViewDiff.InvokeAsync(File)">
    <span class="staging-status @StatusClass">@StatusLetter</span>
    <span class="name" title="@File.Path">@File.FileName</span>
    <span style="margin-left:auto;display:flex;gap:2px;">
        <button class="staging-action-btn" title="Compare (diff)" @onclick="() => OnViewDiff.InvokeAsync(File)">&#9776;</button>
        @if (IsStaged)
        {
            <button class="staging-action-btn" title="Unstage" @onclick="() => OnUnstage.InvokeAsync(File)">&#8722;</button>
        }
        else
        {
            <button class="staging-action-btn" title="Stage" @onclick="() => OnStage.InvokeAsync(File)">&#43;</button>
            <button class="staging-action-btn staging-discard" title="Discard" @onclick="() => OnDiscard.InvokeAsync(File)">&#10007;</button>
        }
    </span>
</div>

@code {
    [Parameter] public FileChange File { get; set; } = default!;
    [Parameter] public bool IsStaged { get; set; }
    [Parameter] public EventCallback<FileChange> OnStage { get; set; }
    [Parameter] public EventCallback<FileChange> OnUnstage { get; set; }
    [Parameter] public EventCallback<FileChange> OnDiscard { get; set; }
    [Parameter] public EventCallback<FileChange> OnViewDiff { get; set; }

    private string StatusLetter => File.Status switch
    {
        FileChangeStatus.Added => "A",
        FileChangeStatus.Modified => "M",
        FileChangeStatus.Deleted => "D",
        FileChangeStatus.Renamed => "R",
        FileChangeStatus.Copied => "C",
        FileChangeStatus.Untracked => "U",
        FileChangeStatus.Conflicted => "!",
        _ => "?"
    };

    private string StatusClass => File.Status switch
    {
        FileChangeStatus.Added or FileChangeStatus.Untracked => "status-added",
        FileChangeStatus.Modified => "status-modified",
        FileChangeStatus.Deleted => "status-deleted",
        FileChangeStatus.Renamed => "status-renamed",
        FileChangeStatus.Conflicted => "status-conflicted",
        _ => "status-modified"
    };
}