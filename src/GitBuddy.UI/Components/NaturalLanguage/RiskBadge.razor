@using GitBuddy.Core.Models
@using GitBuddy.UI.Models

<span class="risk-badge @CssClass">@Label</span>

@code {
    [Parameter, EditorRequired] public RiskLevel Level { get; set; }

    private string CssClass => Level switch
    {
        RiskLevel.Safe => "risk-safe",
        RiskLevel.Moderate => "risk-moderate",
        RiskLevel.Dangerous => "risk-dangerous",
        _ => "risk-safe"
    };

    private string Label => Level switch
    {
        RiskLevel.Safe => "Safe",
        RiskLevel.Moderate => "Moderate",
        RiskLevel.Dangerous => "Dangerous",
        _ => "Safe"
    };
}
