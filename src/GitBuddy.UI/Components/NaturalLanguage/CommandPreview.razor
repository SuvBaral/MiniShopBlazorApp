@using GitBuddy.Core.Models
@using GitBuddy.UI.Models

@if (Translation is not null && !string.IsNullOrEmpty(Translation.Command))
{
    <div class="command-preview">
        <div style="display: flex; align-items: center; gap: 6px;">
            <code>@Translation.Command</code>
            <RiskBadge Level="Translation.Risk" />
            @if (!string.IsNullOrEmpty(Translation.Tier))
            {
                <span style="font-size: 10px; color: var(--vscode-descriptionForeground);">[@Translation.Tier]</span>
            }
        </div>
        <div class="explanation">@Translation.Explanation</div>
        @if (!string.IsNullOrEmpty(Translation.Warning))
        {
            <div style="color: var(--vscode-editorWarning-foreground); margin-top: 4px; font-size: 11px;">
                &#9888; @Translation.Warning
            </div>
        }
    </div>
}
else if (Translation is not null && string.IsNullOrEmpty(Translation.Command))
{
    <div class="command-preview" style="border-left-color: var(--vscode-editorWarning-foreground);">
        <div class="explanation">@Translation.Explanation</div>
    </div>
}

@code {
    [Parameter] public NLTranslation? Translation { get; set; }
}
