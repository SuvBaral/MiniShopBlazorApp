@using GitBuddy.Core.Models
@using GitBuddy.UI.Models
@inject CommandHistoryService HistoryService

@if (Visible && HistoryService.History.Count > 0)
{
    <div class="autocomplete" style="max-height: 300px;">
        <div style="padding: 4px 8px; font-size: 10px; font-weight: 600; text-transform: uppercase; color: var(--vscode-descriptionForeground);">
            Command History
        </div>
        @foreach (var entry in HistoryService.History.Take(20))
        {
            <div class="autocomplete-item" @onclick="() => SelectEntry(entry)">
                <div style="display: flex; flex-direction: column; gap: 1px; flex: 1;">
                    <span style="font-size: 12px;">@entry.NLInput</span>
                    <span style="font-size: 10px; color: var(--vscode-descriptionForeground); font-family: var(--vscode-editor-font-family);">@entry.GitCommand</span>
                </div>
                <span style="font-size: 10px; color: @(entry.Success ? "var(--vscode-testing-iconPassed)" : "var(--vscode-editorError-foreground)");">
                    @(entry.Success ? "&#10003;" : "&#10007;")
                </span>
            </div>
        }
    </div>
}

@code {
    [Parameter] public bool Visible { get; set; }
    [Parameter] public EventCallback<string> OnSelected { get; set; }

    private async Task SelectEntry(CommandHistoryEntry entry)
    {
        await OnSelected.InvokeAsync(entry.NLInput);
    }
}
